# Anthropic — Claude API
ANTHROPIC_API_KEY=

# Catalog data-access selector. `fixture` (default) reads from local TS fixtures —
# the dev-mode default while the dedicated catalog Postgres DB is being provisioned.
# Set to `postgres` once the DB lands and the PostgresCatalogSource is wired
# (see lib/catalog/schema.md, lib/catalog/postgres-source.ts).
CATALOG_SOURCE=fixture

# Postgres + pgvector (catalog + embeddings). Required when CATALOG_SOURCE=postgres.
# Leave blank in dev — FixtureCatalogSource does not touch the DB.
# DATABASE_URL=postgres://user:pass@host:5432/isberian_catalog
DATABASE_URL=

# Upstream inventory source (read-only for ingest).
CATALOG_SOURCE_URL=

# Image pipeline (Cloudinary).
IMAGE_CDN_URL=https://res.cloudinary.com/isberian/image/upload
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=isberian

# CMS (Sanity).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Booking (Cal.com).
SCHEDULER_API_KEY=
CAL_CHICAGO_EVENT=showroom-chicago
CAL_EVANSTON_EVENT=showroom-evanston

# Leads (HubSpot webhook + fallback email).
LEAD_WEBHOOK_URL=
LEAD_EMAIL_TO=info@isberian.com

# Privacy / retention.
SESSION_RETENTION_DAYS=30

# Feature flags
ENABLE_CONCIERGE=true
ENABLE_TRIAGE=true
ENABLE_IDENTIFY=true
